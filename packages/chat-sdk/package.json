{
    "name": "@xclaw-ai/chat-sdk",
    "version": "1.2.0",
    "description": "xClaw Chat SDK — React & React Native client for xClaw AI Agent Platform",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        },
        "./react-native": {
            "types": "./dist/react-native/index.d.ts",
            "import": "./dist/react-native/index.js"
        },
        "./mcp": {
            "types": "./dist/mcp/index.d.ts",
            "import": "./dist/mcp/index.js"
        }
    },
    "bin": {
        "xclaw-chat-mcp": "./dist/mcp/bin.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch",
        "prepublishOnly": "npm run build",
        "mcp": "node dist/mcp/bin.js"
    },
    "keywords": [
        "xclaw",
        "ai",
        "chat",
        "sdk",
        "react",
        "react-native",
        "streaming",
        "sse",
        "mcp"
    ],
    "author": "xDev Asia <dev@xdev.asia>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/xdev-asia-labs/xclaw",
        "directory": "packages/chat-sdk"
    },
    "homepage": "https://github.com/xdev-asia-labs/xclaw/tree/main/packages/chat-sdk",
    "peerDependencies": {
        "react": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1"
    },
    "devDependencies": {
        "@types/react": "^19.2.14",
        "react": "^19.2.4",
        "typescript": "^5.8.0"
    }
}
