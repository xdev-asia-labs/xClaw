{
    "name": "@xclaw-ai/db",
    "version": "2.2.0",
    "description": "xClaw database layer — Drizzle ORM + PostgreSQL",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./mongo": {
            "types": "./dist/mongo.d.ts",
            "import": "./dist/mongo.js"
        }
    },
    "scripts": {
        "build": "tsc -b && cp -r src/migrations dist/migrations",
        "dev": "tsc -b --watch",
        "generate": "npx drizzle-kit@0.31.10 generate",
        "migrate": "npx drizzle-kit@0.31.10 migrate",
        "studio": "npx drizzle-kit@0.31.10 studio"
    },
    "dependencies": {
        "@xclaw-ai/shared": "*",
        "drizzle-orm": "^0.45.2",
        "mongodb": "^7.1.0",
        "postgres": "^3.4.0"
    }
}